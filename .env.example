# AllDebrid-Client — Umgebungsvariablen
# Kopieren nach .env und anpassen.

# Zeitzone
TZ=Europe/Berlin

# Optional: public base URL of the app, so Discord can fetch uploaded avatars
# from outside via /api/avatar.
# Beispiel:
# PUBLIC_BASE_URL=https://example.com

# Only needed when using an internal PostgreSQL container:
# POSTGRES_PASSWORD=sicheres_passwort_hier
