# AllDebrid-Client — Umgebungsvariablen
# Kopieren nach .env und anpassen.

# Zeitzone
TZ=Europe/Berlin

# Optional: öffentliche Basis-URL der App, damit Discord hochgeladene Avatare
# über /api/avatar von außen abrufen kann.
# Beispiel:
# PUBLIC_BASE_URL=https://example.com

# Nur bei internem PostgreSQL-Container nötig:
# POSTGRES_PASSWORD=sicheres_passwort_hier
